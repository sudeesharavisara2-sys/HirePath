<script>
// ===== INLINE ats_dashboard.js (Layout=null bypass fix) =====
document.addEventListener('DOMContentLoaded', function () {
    var dataEl = document.getElementById('dataContainer');
    if (!dataEl) return;
    var atsScore   = parseFloat(dataEl.getAttribute('data-ats')) || 0;
    var confidence = parseFloat(dataEl.getAttribute('data-confidence')) || 0;
    var skills         = JSON.parse(dataEl.getAttribute('data-skills')         || '[]');
    var education      = JSON.parse(dataEl.getAttribute('data-education')      || '[]');
    var certifications = JSON.parse(dataEl.getAttribute('data-certifications') || '[]');
    var strengths      = JSON.parse(dataEl.getAttribute('data-strengths')      || '[]');
    var weaknesses     = JSON.parse(dataEl.getAttribute('data-weaknesses')     || '[]');
    var experience     = JSON.parse(dataEl.getAttribute('data-experience')     || '[]');

    // Gauge fill helper — uses corrected IDs
    function setGauge(fillId, numId, value) {
        var fill = document.getElementById(fillId);
        var num  = document.getElementById(numId);
        if (fill) fill.style.setProperty('--gp', Math.min(value, 100));
        if (num)  num.textContent = Math.round(value);
    }
    setGauge('atsGaugeFill',        'atsGaugeNum',        atsScore);
    setGauge('confidenceGaugeFill', 'confidenceGaugeNum', confidence);

    // Skills cloud
    var skillCloud = document.getElementById('skillCloud');
    if (skillCloud) {
        if (!skills.length) {
            var sp0 = document.createElement('span'); sp0.className = 'missing-tag'; sp0.textContent = 'No skills extracted'; skillCloud.appendChild(sp0);
        } else {
            skills.forEach(function(s) {
                var sp = document.createElement('span'); sp.className='skill-tag'; sp.textContent=s; skillCloud.appendChild(sp);
            });
        }
    }

    // Missing skills
    var required = ['C#','.NET','ASP.NET','ASP.NET Core','Entity Framework','SQL Server','Azure','Microservices','Blazor','Web API','LINQ'];
    var missingEl = document.getElementById('missingSkills');
    if (missingEl) {
        var missingCount = 0;
        required.forEach(function(req) {
            if (!skills.some(function(s){ return new RegExp(req,'i').test(s); })) {
                missingCount++;
                var sp = document.createElement('span'); sp.className='missing-tag'; sp.textContent=req; missingEl.appendChild(sp);
            }
        });
        if (!missingCount) {
            var sp1 = document.createElement('span'); sp1.className = 'skill-tag'; sp1.textContent = 'No gaps detected'; missingEl.appendChild(sp1);
        }
    }

    // Education
    var eduList = document.getElementById('educationList');
    if (eduList) {
        if (!education.length) {
            var li0=document.createElement('li'); li0.textContent='No education found'; eduList.appendChild(li0);
        } else {
            education.forEach(function(item) {
                var li=document.createElement('li'); li.textContent=item; eduList.appendChild(li);
            });
        }
    }

    // Certifications
    var certList = document.getElementById('certList');
    if (certList) {
        if (!certifications.length) {
            var li1=document.createElement('li'); li1.textContent='No certifications found'; certList.appendChild(li1);
        } else {
            certifications.forEach(function(c) {
                var li=document.createElement('li'); li.textContent=c; certList.appendChild(li);
            });
        }
    }

    // Strengths
    var stList = document.getElementById('strengthsList');
    if (stList) {
        if (!strengths.length) {
            var li2=document.createElement('li'); li2.innerHTML='<i class="fas fa-check"></i>No strengths identified'; stList.appendChild(li2);
        } else {
            strengths.forEach(function(s) {
                var li=document.createElement('li'); li.innerHTML='<i class="fas fa-check"></i>'+s; stList.appendChild(li);
            });
        }
    }

    // Weaknesses
    var wkList = document.getElementById('weaknessesList');
    if (wkList) {
        if (!weaknesses.length) {
            var li3=document.createElement('li'); li3.innerHTML='<i class="fas fa-times"></i>No weaknesses identified'; wkList.appendChild(li3);
        } else {
            weaknesses.forEach(function(w) {
                var li=document.createElement('li'); li.innerHTML='<i class="fas fa-times"></i>'+w; wkList.appendChild(li);
            });
        }
    }

    // Experience timeline
    var expTimeline = document.getElementById('expTimeline');
    if (expTimeline) {
        if (!experience.length) {
            var d0=document.createElement('div'); d0.className='timeline-item'; d0.textContent='No experience found'; expTimeline.appendChild(d0);
        } else {
            experience.forEach(function(exp) {
                var d=document.createElement('div'); d.className='timeline-item'; d.innerHTML=exp; expTimeline.appendChild(d);
            });
        }
    }

    // Charts (visible/testable)
    if (typeof Chart !== 'undefined')
    {
        Chart.defaults.color = '#94A3B8';
        Chart.defaults.font.family = 'Inter, -apple-system, sans-serif';

        var dim = {
            skills: parseFloat(dataEl.getAttribute('data-score-skills')) || 0,
            exp: parseFloat(dataEl.getAttribute('data-score-exp')) || 0,
            edu: parseFloat(dataEl.getAttribute('data-score-edu')) || 0,
            proj: parseFloat(dataEl.getAttribute('data-score-proj')) || 0,
            cert: parseFloat(dataEl.getAttribute('data-score-cert')) || 0
        };

        var radarEl = document.getElementById('dimensionRadar');
        if (radarEl)
        {
            new Chart(radarEl, {
                type: 'radar',
                data: {
                    labels: ['Skills', 'Experience', 'Education', 'Projects', 'Certifications'],
                    datasets: [{
                        data: [dim.skills, dim.exp, dim.edu, dim.proj, dim.cert],
                        backgroundColor: 'rgba(16,185,129,0.18)',
                        borderColor: 'rgba(16,185,129,0.85)',
                        pointBackgroundColor: '#10B981',
                        pointBorderColor: '#0B0F19'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        r: {
                            beginAtZero: true,
                            max: 100,
                            grid: { color: 'rgba(255,255,255,0.06)' },
                            angleLines: { color: 'rgba(255,255,255,0.06)' },
                            pointLabels: { color: '#E5E7EB', font: { size: 11, weight: '600' } },
                            ticks: { backdropColor: 'rgba(0,0,0,0)', stepSize: 20 }
                        }
                    }
                }
            });
        }

        var barsEl = document.getElementById('dimensionBars');
        if (barsEl)
        {
            new Chart(barsEl, {
                type: 'bar',
                data: {
                    labels: ['Skills', 'Experience', 'Education', 'Projects', 'Certs'],
                    datasets: [{
                        data: [dim.skills, dim.exp, dim.edu, dim.proj, dim.cert],
                        backgroundColor: ['#10B981', '#F59E0B', '#3B82F6', '#8B5CF6', '#EC4899'],
                        borderRadius: 10,
                        barThickness: 18
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { display: false }, ticks: { color: '#94A3B8' } },
                        y: { beginAtZero: true, max: 100, grid: { color: 'rgba(255,255,255,0.06)' }, ticks: { stepSize: 20 } }
                    }
                }
            });
        }
    }
});
</script>
<script>
    const fileInput = document.getElementById('resumeFile');
    const textarea = document.getElementById('resumeText');
    const form = document.getElementById('resumeForm');
    const progressBar = document.getElementById('uploadProgress');
    const overlay = document.getElementById('analysisOverlay');
    const dropZone = document.getElementById('dropZone');
    const fileInfo = document.getElementById('fileInfo');
    const fileName = document.getElementById('fileName');
    const particleContainer = document.getElementById('particleContainer');
    const wfSteps = Array.from(document.querySelectorAll('[data-wf]'));

    function resetWorkflowUI() {
        wfSteps.forEach(el => {
            el.setAttribute('data-state', 'pending');
            const pill = el.querySelector('.wf-pill');
            if (pill) pill.textContent = 'Waiting';
        });
    }

    function setWorkflowStep(key, state) {
        const el = document.querySelector(`[data-wf="${key}"]`);
        if (!el) return;
        el.setAttribute('data-state', state);
        const pill = el.querySelector('.wf-pill');
        if (!pill) return;
        if (state === 'active') pill.textContent = 'In progress';
        else if (state === 'done') pill.textContent = 'Done';
        else pill.textContent = 'Waiting';
    }

    // Helper to create simple particles
    function spawnParticles() {
        const colors = ['#10B981', '#F59E0B', '#EF4444'];
        for (let i = 0; i < 15; i++) {
            const particle = document.createElement('div');
            particle.className = 'particle';
            const size = Math.random() * 6 + 4;
            particle.style.width = size + 'px';
            particle.style.height = size + 'px';
            particle.style.background = colors[Math.floor(Math.random() * colors.length)];
            particle.style.position = 'absolute';
            particle.style.left = Math.random() * 100 + '%';
            particle.style.top = Math.random() * 100 + '%';
            particle.style.borderRadius = '50%';
            particle.style.opacity = 0.8;
            particle.style.transform = `scale(${Math.random() + 0.5})`;
            particleContainer.appendChild(particle);
            setTimeout(() => particle.remove(), 1200);
        }
    }

    // Drag & drop handling
    if (dropZone) {
        dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('dragover'); });
        dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
        dropZone.addEventListener('drop', e => {
            e.preventDefault();
            dropZone.classList.remove('dragover');
            if (e.dataTransfer.files.length) {
                fileInput.files = e.dataTransfer.files;
                handleFile(e.dataTransfer.files[0]);
            }
        });
    }

    function handleFile(file) {
        if (file.type !== 'application/pdf') {
            fileInput.classList.add('invalid');
            setTimeout(() => fileInput.classList.remove('invalid'), 600);
            alert('Only PDF files accepted.');
            fileInput.value = '';
            return;
        }
        fileInfo.style.display = 'block';
        fileName.textContent = `${file.name} (${(file.size / 1024).toFixed(1)} KB)`;
        document.querySelector('.drop-zone h4').textContent = 'Ready: ' + file.name;
        document.querySelector('.drop-zone p').style.display = 'none';

        // Show progress bar animation
        if (progressBar) {
            progressBar.style.display = 'block';
            progressBar.querySelector('.progress-fill').style.width = '0%';
            setTimeout(() => {
                progressBar.querySelector('.progress-fill').style.width = '100%';
            }, 200);
        }

        // Show PDF preview
        const preview = document.getElementById('pdfPreview');
        if (preview) {
            preview.innerHTML = `<iframe src="${URL.createObjectURL(file)}" style="width:100%;height:300px;border:none;"></iframe>`;
            preview.style.display = 'block';
        }
    }

    // File input change
    if (fileInput) {
        fileInput.addEventListener('change', () => {
            if (fileInput.files.length) {
                handleFile(fileInput.files[0]);
                if (textarea) textarea.value = '';
            }
        });
    }

    // Textarea input – clear file selection
    if (textarea) {
        textarea.addEventListener('input', () => {
            if (textarea.value.trim()) {
                fileInput.value = '';
                fileInfo.style.display = 'none';
                document.querySelector('.drop-zone h4').textContent = 'Drop resume PDF here';
                document.querySelector('.drop-zone p').style.display = '';
            }
        });
    }

    // Form submit
    if (form) {
        let submitting = false;
        form.addEventListener('submit', function (e) {
            if (submitting) return;
            const text = textarea ? textarea.value.trim() : '';
            const file = fileInput ? fileInput.files[0] : null;
            if (!text && !file) {
                e.preventDefault();
                alert('Please upload a PDF or paste resume text.');
                return;
            }
            e.preventDefault();
            if (overlay) overlay.classList.add('show');
            resetWorkflowUI();
            spawnParticles();
            submitting = true;

            // Prefer real server-driven workflow states via streaming.
            // Falls back to normal form post if streaming isn't available.
            const fd = new FormData(form);
            startWorkflowStream(fd)
                .catch(() => form.submit());
        });
    }

    async function startWorkflowStream(formData) {
        if (!window.fetch || !window.TextDecoder) throw new Error('streaming not supported');
        const res = await fetch('/Resume/AnalyzeStream', {
            method: 'POST',
            body: formData,
            headers: { 'Accept': 'text/event-stream' }
        });
        if (!res.ok || !res.body) throw new Error('streaming response not available');

        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buffer = '';

        const handleEventBlock = (block) => {
            let eventName = 'message';
            const dataLines = [];
            block.split('\n').forEach(line => {
                if (line.startsWith('event:')) eventName = line.slice(6).trim();
                if (line.startsWith('data:')) dataLines.push(line.slice(5).trim());
            });
            const dataRaw = dataLines.join('\n');
            if (!dataRaw) return;
            let payload;
            try { payload = JSON.parse(dataRaw); } catch { payload = null; }

            if (eventName === 'step' && payload && payload.key && payload.state) {
                setWorkflowStep(payload.key, payload.state);
            } else if (eventName === 'done' && payload && payload.resultId) {
                window.location.href = `/Resume/Result?id=${encodeURIComponent(payload.resultId)}`;
            } else if (eventName === 'error') {
                const msg = payload && payload.message ? payload.message : 'Analysis failed.';
                alert(msg);
                if (overlay) overlay.classList.remove('show');
            }
        };

        while (true) {
            const { value, done } = await reader.read();
            if (done) break;
            buffer += decoder.decode(value, { stream: true });
            let idx;
            while ((idx = buffer.indexOf('\n\n')) >= 0) {
                const block = buffer.slice(0, idx);
                buffer = buffer.slice(idx + 2);
                if (block.trim()) handleEventBlock(block);
            }
        }
    }

    @if (hasResult)
    {
        @:
        @:    var previewText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ResumeText?.ToString() ?? ""));
        @:    var skillList = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ParsedSkills as List<string> ?? new()));
        @:    var emailVal = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ParsedEmail?.ToString() ?? ""));
        @:    var phoneVal = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ParsedPhone?.ToString() ?? ""));
        @:
        @:    function esc(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
        @:    function highlightText(txt, items, className) {
        @:        items.forEach(function(item) {
        @:            var escaped = item.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        @:            var re = new RegExp('\\b' + escaped + '\\b', 'gi');
        @:            txt = txt.replace(re, function(m) { return '<span class="' + className + '">' + m + '</span>'; });
        @:        });
        @:        return txt;
        @:    }
        @:
        @:    var previewEl = document.getElementById('previewText');
        @:    if (previewEl && previewText) {
        @:        var txt = esc(previewText);
        @:        txt = highlightText(txt, skillList, 'hl-skill');
        @:        if (emailVal) txt = txt.replace(new RegExp(emailVal.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\$&'), 'g'), '<span class="hl-email">' + emailVal + '</span>');
        @:        if (phoneVal) txt = txt.replace(new RegExp(phoneVal.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\$&'), 'g'), '<span class="hl-phone">' + phoneVal + '</span>');
        @:        previewEl.innerHTML = txt;
        @:    }
    }

    function resetForm() {
        window.location.
        href = '/Resume';
    }
</script>
</body>
