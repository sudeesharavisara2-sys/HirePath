@model HirePathAI.Application.DTOs.JobRequirementDto
@{
    ViewData["Title"] = Model.Title + " Details";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Title - Resume AI</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', -apple-system, sans-serif; background: #0B0F19; color: #F9FAFB; min-height: 100vh; }
        .nav { background: rgba(17,24,39,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.06); padding: 0 2rem; height: 60px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
        .nav-brand { display: flex; align-items: center; gap: 0.75rem; color: #F9FAFB; text-decoration: none; font-weight: 700; font-size: 1.05rem; }
        .nav-brand i { font-size: 1.3rem; color: #10B981; }
        .nav-links { display: flex; gap: 0.25rem; }
        .nav-link { color: #94A3B8; text-decoration: none; padding: 0.4rem 1rem; border-radius: 8px; font-size: 0.85rem; font-weight: 500; transition: all 0.2s; }
        .nav-link:hover { color: #F9FAFB; background: rgba(255,255,255,0.05); }
        .nav-link.active { color: #10B981; background: rgba(16,185,129,0.1); }
        
        .main { flex: 1; padding: 2rem; max-width: 800px; margin: 0 auto; width: 100%; }
        .page-header { margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center; }
        .page-title { font-size: 1.8rem; font-weight: 700; color: #E5E7EB; margin-bottom: 0.5rem; }
        .page-desc { color: #94A3B8; font-size: 1rem; }
        
        .card { background: #111827; border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; padding: 2rem; margin-bottom: 2rem; }
        .section-title { font-size: 1.1rem; font-weight: 600; color: #F9FAFB; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.06); }
        
        .tag-list { display: flex; flex-wrap: wrap; gap: 0.5rem; }
        .tag { background: rgba(255,255,255,0.05); color: #D1D5DB; padding: 0.3rem 0.8rem; border-radius: 8px; font-size: 0.85rem; font-weight: 500; }
        .tag.req { background: rgba(16,185,129,0.1); color: #10B981; border: 1px solid rgba(16,185,129,0.2); }
        
        .btn-primary { background: #10B981; color: #fff; text-decoration: none; padding: 0.6rem 1.2rem; border-radius: 8px; font-size: 0.85rem; font-weight: 600; transition: all 0.2s; display: inline-block; }
        .btn-primary:hover { background: #059669; }
        
        .btn-secondary { background: rgba(255,255,255,0.05); color: #D1D5DB; text-decoration: none; padding: 0.6rem 1.2rem; border-radius: 8px; font-size: 0.85rem; font-weight: 600; transition: all 0.2s; display: inline-block; border: 1px solid rgba(255,255,255,0.1); }
        .btn-secondary:hover { background: rgba(255,255,255,0.1); }
    </style>
</head>
<body>

<div class="nav">
    <a href="/" class="nav-brand"><i class="fas fa-sparkles"></i>Resume AI</a>
    <div class="nav-links">
        <a href="/" class="nav-link"><i class="fas fa-home me-1"></i>Home</a>
        <a href="/Job" class="nav-link active"><i class="fas fa-briefcase me-1"></i>Jobs</a>
        <a href="/Resume" class="nav-link"><i class="fas fa-file-alt me-1"></i>Screening</a>
    </div>
</div>

<main class="main">
    <div class="page-header">
        <div>
            <h1 class="page-title">@Model.Title</h1>
            <p class="page-desc"><i class="fas fa-building me-1"></i> @Model.CompanyName &middot; <i class="fas fa-layer-group me-1"></i> @Model.Department</p>
        </div>
        <div style="display:flex; gap:0.5rem;">
            <a href="/Job/Edit/@Model.Id" class="btn-secondary"><i class="fas fa-edit me-2"></i> Edit</a>
            <a href="/Resume?jobId=@Model.Id" class="btn-primary"><i class="fas fa-users me-2"></i> Screen Candidates</a>
        </div>
    </div>

    <div class="card">
        <h3 class="section-title"><i class="fas fa-cog me-2"></i> Required Skills</h3>
        <div class="tag-list" style="margin-bottom: 2rem;">
            @if(Model.RequiredSkills.Any())
            {
                foreach(var skill in Model.RequiredSkills)
                {
                    <span class="tag req">@skill</span>
                }
            }
            else
            {
                <span class="tag">No required skills specified</span>
            }
        </div>

        <h3 class="section-title"><i class="fas fa-plus-circle me-2"></i> Preferred Skills</h3>
        <div class="tag-list" style="margin-bottom: 2rem;">
            @if(Model.PreferredSkills.Any())
            {
                foreach(var skill in Model.PreferredSkills)
                {
                    <span class="tag">@skill</span>
                }
            }
            else
            {
                <span class="tag">No preferred skills specified</span>
            }
        </div>

        <h3 class="section-title"><i class="fas fa-briefcase me-2"></i> Requirements</h3>
        <div style="display: flex; gap: 2rem; color: #D1D5DB;">
            <div>
                <strong style="display:block; font-size:0.8rem; color:#94A3B8; margin-bottom:0.2rem;">Experience</strong>
                @Model.MinimumYearsExperience+ Years
            </div>
            <div>
                <strong style="display:block; font-size:0.8rem; color:#94A3B8; margin-bottom:0.2rem;">Education Level</strong>
                @Model.MinimumEducationLevel
            </div>
        </div>
    </div>
</main>

</body>
</html>
