@model IEnumerable<HirePathAI.Application.DTOs.JobRequirementDto>
@{
    ViewData["Title"] = "Active Jobs";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Active Jobs - Resume AI</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', -apple-system, sans-serif; background: #0B0F19; color: #F9FAFB; min-height: 100vh; }
        .nav { background: rgba(17,24,39,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.06); padding: 0 2rem; height: 60px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
        .nav-brand { display: flex; align-items: center; gap: 0.75rem; color: #F9FAFB; text-decoration: none; font-weight: 700; font-size: 1.05rem; }
        .nav-brand i { font-size: 1.3rem; color: #10B981; }
        .nav-links { display: flex; gap: 0.25rem; }
        .nav-link { color: #94A3B8; text-decoration: none; padding: 0.4rem 1rem; border-radius: 8px; font-size: 0.85rem; font-weight: 500; transition: all 0.2s; }
        .nav-link:hover { color: #F9FAFB; background: rgba(255,255,255,0.05); }
        .nav-link.active { color: #10B981; background: rgba(16,185,129,0.1); }
        
        .main { flex: 1; padding: 2rem; max-width: 1400px; margin: 0 auto; width: 100%; }
        .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
        .page-title { font-size: 1.5rem; font-weight: 700; color: #E5E7EB; }
        
        .btn-primary { background: #10B981; color: #fff; text-decoration: none; padding: 0.6rem 1.2rem; border-radius: 8px; font-size: 0.85rem; font-weight: 600; transition: all 0.2s; display: inline-block; }
        .btn-primary:hover { background: #059669; transform: translateY(-1px); }

        .job-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.25rem; }
        .job-card { background: #111827; border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; padding: 1.5rem; transition: all 0.2s; display: flex; flex-direction: column; }
        .job-card:hover { border-color: rgba(16,185,129,0.4); transform: translateY(-2px); box-shadow: 0 10px 30px -10px rgba(16,185,129,0.15); }
        .job-title { font-size: 1.1rem; font-weight: 600; color: #F9FAFB; margin-bottom: 0.3rem; }
        .job-company { font-size: 0.85rem; color: #94A3B8; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.4rem; }
        .job-company i { color: #6366F1; }
        
        .tag-list { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1.5rem; }
        .tag { background: rgba(255,255,255,0.05); color: #D1D5DB; padding: 0.2rem 0.6rem; border-radius: 6px; font-size: 0.75rem; font-weight: 500; }
        .tag.req { background: rgba(16,185,129,0.1); color: #10B981; border: 1px solid rgba(16,185,129,0.2); }
        
        .card-footer { margin-top: auto; padding-top: 1rem; border-top: 1px solid rgba(255,255,255,0.06); display: flex; justify-content: space-between; align-items: center; }
        .meta-info { font-size: 0.75rem; color: #6B7280; }
        .btn-action { color: #10B981; text-decoration: none; font-size: 0.85rem; font-weight: 600; display: flex; align-items: center; gap: 0.4rem; }
        .btn-action:hover { color: #34D399; }
    </style>
</head>
<body>

<div class="nav">
    <a href="/" class="nav-brand"><i class="fas fa-sparkles"></i>Resume AI</a>
    <div class="nav-links">
        <a href="/" class="nav-link"><i class="fas fa-home me-1"></i>Home</a>
        <a href="/Job" class="nav-link active"><i class="fas fa-briefcase me-1"></i>Jobs</a>
        <a href="/Resume" class="nav-link"><i class="fas fa-file-alt me-1"></i>Screening</a>
    </div>
</div>

<main class="main">
    <div class="page-header">
        <h1 class="page-title">Active Jobs</h1>
        <a href="/Job/Create" class="btn-primary"><i class="fas fa-plus me-2"></i> Create Job Requirement</a>
    </div>

    @if (!Model.Any())
    {
        <div style="text-align:center; padding: 4rem; background: #111827; border-radius: 12px; border: 1px dashed rgba(255,255,255,0.1);">
            <i class="fas fa-folder-open" style="font-size: 3rem; color: #4B5563; margin-bottom: 1rem;"></i>
            <h3 style="color: #E5E7EB; margin-bottom: 0.5rem;">No job roles defined</h3>
            <p style="color: #94A3B8; margin-bottom: 1.5rem; font-size: 0.9rem;">Create a job requirement to start screening resumes against it.</p>
            <a href="/Job/Create" class="btn-primary">Create First Job</a>
        </div>
    }
    else
    {
        <div class="job-grid">
            @foreach (var job in Model)
            {
                <div class="job-card">
                    <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                        <div>
                            <div class="job-title"><a href="/Job/Details/@job.Id" style="color:inherit; text-decoration:none;">@job.Title</a></div>
                            <div class="job-company"><i class="fas fa-building"></i> @job.CompanyName &middot; @job.Department</div>
                        </div>
                        <div style="display:flex; gap:0.5rem;">
                            <a href="/Job/Edit/@job.Id" style="color:#94A3B8;" title="Edit"><i class="fas fa-edit"></i></a>
                            <form method="post" action="/Job/Delete/@job.Id" onsubmit="return confirm('Delete this job role?');" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" style="background:none; border:none; color:#EF4444; cursor:pointer;" title="Delete"><i class="fas fa-trash"></i></button>
                            </form>
                        </div>
                    </div>
                    
                    <div class="tag-list">
                        @foreach (var skill in job.RequiredSkills.Take(4))
                        {
                            <span class="tag req">@skill</span>
                        }
                        @if (job.RequiredSkills.Count > 4)
                        {
                            <span class="tag">+@(job.RequiredSkills.Count - 4) more</span>
                        }
                    </div>
                    
                    <div class="card-footer">
                        <div class="meta-info"><i class="fas fa-briefcase"></i> @job.MinimumYearsExperience+ yrs &middot; <i class="fas fa-graduation-cap"></i> @job.MinimumEducationLevel</div>
                        <a href="/Resume?jobId=@job.Id" class="btn-action">Screen <i class="fas fa-arrow-right"></i></a>
                    </div>
                </div>
            }
        </div>
    }
</main>

</body>
</html>
