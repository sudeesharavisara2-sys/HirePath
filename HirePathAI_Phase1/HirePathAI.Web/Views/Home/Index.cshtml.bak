@{
    ViewData["Title"] = "AI Resume Screening";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AI Resume Screening Platform</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', -apple-system, sans-serif; background: #0B0F19; color: #F9FAFB; min-height: 100vh; display: flex; flex-direction: column; }
        .nav { background: rgba(17,24,39,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.06); padding: 0 2rem; height: 60px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
        .nav-brand { display: flex; align-items: center; gap: 0.75rem; color: #F9FAFB; text-decoration: none; font-weight: 700; font-size: 1.05rem; }
        .nav-brand:hover { color: #10B981; }
        .nav-brand i { font-size: 1.3rem; color: #10B981; }
        .nav-links { display: flex; gap: 0.25rem; }
        .nav-link { color: #94A3B8; text-decoration: none; padding: 0.4rem 1rem; border-radius: 8px; font-size: 0.85rem; font-weight: 500; transition: all 0.2s; }
        .nav-link:hover { color: #F9FAFB; background: rgba(255,255,255,0.05); }
        .nav-link.active { color: #10B981; background: rgba(16,185,129,0.1); }
        .main { flex: 1; display: flex; align-items: center; justify-content: center; padding: 2rem; }
        .hero { text-align: center; max-width: 640px; }
        .hero-icon { font-size: 3rem; color: #10B981; margin-bottom: 1.5rem; }
        .hero h1 { font-size: 2.5rem; font-weight: 800; letter-spacing: -0.02em; line-height: 1.2; margin-bottom: 1rem; }
        .hero h1 span { color: #10B981; }
        .hero p { color: #94A3B8; font-size: 1.05rem; line-height: 1.6; margin-bottom: 2rem; }
        .hero-btn { display: inline-flex; align-items: center; gap: 0.6rem; background: #10B981; color: #fff; padding: 0.9rem 2.5rem; border-radius: 12px; font-size: 1rem; font-weight: 600; text-decoration: none; transition: all 0.2s; }
        .hero-btn:hover { background: #059669; transform: translateY(-2px); box-shadow: 0 8px 30px rgba(16,185,129,0.3); color: #fff; }
        .features { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 3rem; text-align: left; }
        .feature-card { background: #111827; border: 1px solid rgba(255,255,255,0.06); border-radius: 14px; padding: 1.5rem; transition: border-color 0.2s; }
        .feature-card:hover { border-color: rgba(16,185,129,0.3); }
        .feature-icon { width: 40px; height: 40px; border-radius: 10px; background: rgba(16,185,129,0.1); display: flex; align-items: center; justify-content: center; color: #10B981; font-size: 1.1rem; margin-bottom: 0.75rem; }
        .feature-card h3 { font-size: 0.95rem; font-weight: 600; margin-bottom: 0.35rem; }
        .feature-card p { font-size: 0.82rem; color: #6B7280; line-height: 1.5; }
        .footer { text-align: center; padding: 1.5rem; color: #4B5563; font-size: 0.8rem; border-top: 1px solid rgba(255,255,255,0.04); }
        @media (max-width: 640px) { .features { grid-template-columns: 1fr; } .hero h1 { font-size: 1.8rem; } }
    </style>
</head>
<body>
    <nav class="nav">
        <a href="/" class="nav-brand"><i class="fas fa-sparkles"></i>Resume AI</a>
        <div class="nav-links">
            <a href="/" class="nav-link active"><i class="fas fa-home me-1"></i>Home</a>
            <a href="/Resume" class="nav-link"><i class="fas fa-file-alt me-1"></i>Screening</a>
        </div>
    </nav>
    <main class="main">
        <div class="hero">
            <div class="hero-icon"><i class="fas fa-microchip"></i></div>
            <h1>AI-Powered <span>Resume Screening</span></h1>
            <p>Upload resumes and get instant ML-powered analysis of skills, experience, education, and candidate fit. Built with ML.NET and Clean Architecture.</p>
            <a href="/Resume" class="hero-btn"><i class="fas fa-upload"></i>Start Screening</a>
            <div class="features">
                <div class="feature-card">
                    <div class="feature-icon"><i class="fas fa-brain"></i></div>
                    <h3>ML.NET Prediction</h3>
                    <p>Trained model analyzes resume text to predict candidate suitability with confidence scoring</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon"><i class="fas fa-user-cog"></i></div>
                    <h3>Smart Parsing</h3>
                    <p>Extracts name, email, phone, skills, education, experience, and certifications automatically</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon"><i class="fas fa-chart-bar"></i></div>
                    <h3>Multi-Dimension Scoring</h3>
                    <p>Weighted evaluation across skills, experience, education, projects, and certifications</p>
                </div>
            </div>
        </div>
    </main>
    <div class="footer">&copy; 2026 Resume AI Screening Platform. Built with ML.NET.</div>
</body>
</html>
