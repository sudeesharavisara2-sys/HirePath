@{
    ViewData["Title"] = "ATS Resume Analysis";
    var jobs = ViewBag.Jobs;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h2 class="mb-2">
                        ATS Resume Analysis
                    </h2>

                    <p class="text-muted mb-4">
                        Upload a candidate resume and compare it
                        against an active job.
                    </p>

                    <div id="atsAlert"
                         class="alert d-none"
                         role="alert">
                    </div>

                    <form id="atsAnalysisForm">
                        <div class="mb-3">
                            <label for="jobId"
                                   class="form-label">
                                Select job
                            </label>

                            <select id="jobId"
                                    name="jobId"
                                    class="form-select"
                                    required>
                                <option value="">
                                    Select a job
                                </option>

                                @if (jobs != null)
                                {
                                    foreach (var job in jobs)
                                    {
                                        <option value="@job.Id">
                                            @job.Title -
                                            @job.CompanyName
                                        </option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="resumeFile"
                                   class="form-label">
                                Resume PDF
                            </label>

                            <input id="resumeFile"
                                   name="resumeFile"
                                   class="form-control"
                                   type="file"
                                   accept=".pdf,application/pdf"
                                   required />

                            <div class="form-text">
                                Maximum size: 10 MB.
                            </div>
                        </div>

                        <button id="analyzeButton"
                                type="submit"
                                class="btn btn-primary">
                            Analyse Resume
                        </button>
                    </form>
                </div>
            </div>

            <div id="loadingPanel"
                 class="card shadow-sm border-0 mt-4 d-none">
                <div class="card-body text-center py-5">
                    <div class="spinner-border text-primary"
                         role="status">
                    </div>

                    <p class="mt-3 mb-0">
                        Analysing the resume...
                    </p>
                </div>
            </div>

            <div id="resultPanel"
                 class="card shadow-sm border-0 mt-4 d-none">
                <div class="card-body p-4">
                    <div class="d-flex flex-wrap
                                justify-content-between
                                align-items-start gap-3">
                        <div>
                            <h3 id="candidateName"
                                class="mb-1">
                            </h3>

                            <p id="candidateContact"
                               class="text-muted mb-0">
                            </p>
                        </div>

                        <div class="text-end">
                            <div class="fs-2 fw-bold"
                                 id="atsScore">
                            </div>

                            <span class="text-muted">
                                ATS score
                            </span>
                        </div>
                    </div>

                    <hr />

                    <div class="row g-3 mb-4">
                        <div class="col-md-3">
                            <div class="border rounded p-3">
                                <small class="text-muted">
                                    Match
                                </small>

                                <div id="matchPercentage"
                                     class="fs-4 fw-semibold">
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="border rounded p-3">
                                <small class="text-muted">
                                    Skills
                                </small>

                                <div id="skillsScore"
                                     class="fs-4 fw-semibold">
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="border rounded p-3">
                                <small class="text-muted">
                                    Experience
                                </small>

                                <div id="experienceScore"
                                     class="fs-4 fw-semibold">
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="border rounded p-3">
                                <small class="text-muted">
                                    Education
                                </small>

                                <div id="educationScore"
                                     class="fs-4 fw-semibold">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h5>Recommendation</h5>

                        <div id="recommendation"
                             class="alert alert-info mb-0">
                        </div>
                    </div>

                    <div class="mb-4">
                        <h5>Summary</h5>

                        <p id="analysisSummary"
                           class="text-muted">
                        </p>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-4">
                            <h5>Extracted skills</h5>

                            <div id="extractedSkills"
                                 class="d-flex flex-wrap gap-2">
                            </div>
                        </div>

                        <div class="col-md-4">
                            <h5>Matched skills</h5>

                            <div id="matchedSkills"
                                 class="d-flex flex-wrap gap-2">
                            </div>
                        </div>

                        <div class="col-md-4">
                            <h5>Missing skills</h5>

                            <div id="missingSkills"
                                 class="d-flex flex-wrap gap-2">
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div class="row g-4">
                        <div class="col-md-4">
                            <h5>Education</h5>
                            <ul id="educationList"></ul>
                        </div>

                        <div class="col-md-4">
                            <h5>Experience</h5>
                            <ul id="experienceList"></ul>
                        </div>

                        <div class="col-md-4">
                            <h5>Certifications</h5>
                            <ul id="certificationList"></ul>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 mt-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between
                                align-items-center mb-3">
                        <h3 class="h5 mb-0">
                            Previous analyses
                        </h3>

                        <button id="refreshAnalysesButton"
                                type="button"
                                class="btn btn-outline-secondary btn-sm">
                            Refresh
                        </button>
                    </div>

                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Candidate</th>
                                    <th>Job</th>
                                    <th>ATS score</th>
                                    <th>Match</th>
                                    <th>Recommendation</th>
                                    <th>Date</th>
                                </tr>
                            </thead>

                            <tbody id="analysisTableBody">
                                <tr>
                                    <td colspan="6"
                                        class="text-center text-muted">
                                        Loading...
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script src="~/js/ats-api.js"
            asp-append-version="true"></script>
}